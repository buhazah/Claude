# Client (Expo) — safe to expose, protected by RLS
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server only — set as Supabase Edge Function secrets (never in the client)
# supabase secrets set ANTHROPIC_API_KEY=... DEEPGRAM_API_KEY=... STRIPE_SECRET_KEY=...
ANTHROPIC_API_KEY=
DEEPGRAM_API_KEY=
STRIPE_SECRET_KEY=
PERSONA_API_KEY=
GOOGLE_PLACES_API_KEY=
